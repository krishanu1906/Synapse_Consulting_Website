{
  "name": "synapse-consulting",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Synapse Consulting — Boutique Retail & CPG Data & Analytics Consultancy",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "dev:full": "concurrently -n web,api -c blue,magenta \"npm run dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "nodemailer": "^6.9.14",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "concurrently": "^8.2.2"
  }
}
