# ───────────────────────────────────────────────
# Synapse Consulting — Email backend configuration
# Copy this file to `.env` and fill in your SMTP details.
# ───────────────────────────────────────────────

# Backend port (frontend dev server proxies /api to this)
PORT=3001

# SMTP server settings
# Examples:
#  - Google Workspace:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
#  - SendGrid:          SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false  SMTP_USER=apikey
#  - AWS SES:           SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587  SMTP_SECURE=false
#  - Zoho Mail:         SMTP_HOST=smtp.zoho.in  SMTP_PORT=465  SMTP_SECURE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-mailbox@synapseconsulting.in
SMTP_PASS=your-smtp-password-or-app-password

# Address that receives website enquiries
CONTACT_EMAIL=contact@synapseconsulting.in

# Sender identity used on outbound emails (notifications + auto-replies)
FROM_EMAIL=contact@synapseconsulting.in
FROM_NAME=Synapse Consulting
